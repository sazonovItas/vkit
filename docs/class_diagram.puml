@startuml class_diagram
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 50
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #333333
    FontSize 11
}
skinparam package {
    BackgroundColor #F8F8F8
    BorderColor #888888
    FontSize 12
    FontStyle bold
}
skinparam arrow {
    FontSize 9
}

title Importing, Applying and Generating Materials for 3D Models\nusing Procedural Methods (Vulkan / vkit)

' ─────────────────────────────────────────────
' PACKAGE: Asset Import
' ─────────────────────────────────────────────
package "Asset Import (glTF)" {

    class AssetManager {
        - device_: GfxDevice&
        - storage_: shared_ptr<GltfStorage>
        - gcQueue_: vector<GCTask>
        + loadGltfAsset(path): shared_ptr<Asset>
        + removeGltfAsset(id)
        + processGC()
    }

    class AssetImporter {
        - device_: GfxDevice&
        - buffers_: shared_ptr<DeviceBuffers>
        + load(path): shared_ptr<Asset>
        - loadMeshes()
        - loadNodes()
        - loadSkins()
        - loadAnimations()
    }

    class Asset {
        - nodes_: NodeStorage
        - meshes_: MeshStorage
        - primitives_: PrimitiveStorage
        - scenes_: vector<Scene>
        - animations_: vector<Animation>
        + getActiveScene(): Scene&
        + setActiveScene(idx)
        + update()
    }
}

' ─────────────────────────────────────────────
' PACKAGE: Scene Graph
' ─────────────────────────────────────────────
package "Scene Graph" {

    class Scene {
        - rootNodes: vector<uint32_t>
        + addRootNode(id)
    }

    class Node {
        - mesh_: shared_ptr<Mesh>
        - skin_: shared_ptr<Skin>
        - parent_: weak_ptr<Node>
        - children_: vector<shared_ptr<Node>>
        - localTransform_: TrsTransform
        - worldTransform_: TrsTransform
        + getGlobalTransform(): mat4
        + addChild(node)
        + setLocalTransform(trs)
    }

    class Mesh {
        - primitives_: vector<shared_ptr<Primitive>>
        + addPrimitive(p)
        + getPrimitives(): vector<Primitive>
    }

    class Primitive {
        - buffers_: shared_ptr<DeviceBuffers>
        - materialSlot_: uint32_t
        - attributes_: DevicePrimitiveAttributes
        - vertexMode_: PrimitiveVertexMode
        + getData(): PrimitiveData
        + getIndexBuffer(): DeviceBuffer
    }

    class Animation {
        - samplers: vector<AnimationSampler>
        - channels: vector<AnimationChannel>
        - start: float
        - end: float
    }

    class Skin {
        - joints: vector<shared_ptr<Node>>
        - inverseBindMatrices: vector<mat4>
    }
}

' ─────────────────────────────────────────────
' PACKAGE: Texture System
' ─────────────────────────────────────────────
package "Texture System" {

    class TextureManager {
        - bindlessMgr_: BindlessTextureManager*
        - gcQueue_: vector<GCTask>
        + add(info): shared_ptr<Texture>
        + remove(id)
        + processGC()
    }

    class Texture {
        - texture_: shared_ptr<gfx::Texture>
        - bindlessId_: uint32_t
        - storageId_: uint32_t
        + getBindlessId(): uint32_t
        + getGraphicsTexture(): gfx::Texture
    }

    class "gfx::Texture" as GfxTexture {
        - image_: AllocatedImage
        - view_: vk::UniqueImageView
        - sampler_: vk::Sampler
        - type_: TextureType
        - useMipmaps_: bool
        + recordUpload(cmd)
        + recordMipmapGeneration(cmd)
        + getWidth(): uint32_t
        + getHeight(): uint32_t
    }

    class Environment {
        - brdfLutTexture_: shared_ptr<Texture>
        - irradianceTexture_: shared_ptr<Texture>
        - prefilterTexture_: shared_ptr<Texture>
        - intensity_: float
        - features_: uint32_t
        + getData(): EnvironmentParams
    }
}

' ─────────────────────────────────────────────
' PACKAGE: Material System
' ─────────────────────────────────────────────
package "Material System" {

    abstract class Material {
        - isDirty_: bool
        - alphaMode_: AlphaMode
        - doubleSided_: bool
        + {abstract} getType(): Type
        + markDirty()
    }

    class Diffuse {
        - diffuseTex_: shared_ptr<Texture>
        - normalTex_: shared_ptr<Texture>
        - params: Params
        --
        struct Params
        .. diffuseFactor: vec4 ..
    }

    class DiffuseSpecular {
        - diffuseTex_: shared_ptr<Texture>
        - specGlossTex_: shared_ptr<Texture>
        - normalTex_: shared_ptr<Texture>
        - params: Params
        --
        struct Params
        .. diffuseFactor: vec4 ..
        .. specularFactor: vec3 ..
        .. glossinessFactor: float ..
    }

    class PrincipledBSDF {
        - textures_: shared_ptr<Texture>[15]
        - params: Params
        - features_: uint32_t
        --
        struct Params (160 bytes)
        .. baseColorFactor: vec4 ..
        .. metallicFactor: float ..
        .. roughnessFactor: float ..
        .. emissiveFactor: vec3 ..
        .. ior: float ..
        .. transmissionFactor: float ..
        + enableFeature(f: Feature)
        + hasFeature(f: Feature): bool
        + getData(): Data
    }

    class Slot {
        - type_: Material::Type
        - id_: uint32_t
    }

    class MaterialManager {
        - diffuse_: TypedStorage<Diffuse>
        - diffSpec_: TypedStorage<DiffuseSpecular>
        - principled_: TypedStorage<PrincipledBSDF>
        - slots_: Storage<Slot>
        + addMaterial<T>(): shared_ptr<T>
        + removeMaterial(id)
        + update()
    }
}

' ─────────────────────────────────────────────
' PACKAGE: Procedural Workflow
' ─────────────────────────────────────────────
package "Procedural Workflow" {

    class Workflow {
        - nodes_: vector<unique_ptr<WorkflowNode>>
        - isDirty_: bool
        + execute()
        + createNode<T>(): T*
        + destroyNode(id)
        + connect(from, to)
        + disconnect(link)
        + canConnect(from, to): bool
    }

    abstract class WorkflowNode {
        - name_: string
        - status_: NodeStatus
        - isDirty_: bool
        - inputPins_: vector<Pin>
        - outputPins_: vector<Pin>
        + {abstract} execute()
        + markStale()
        + propagateStale()
    }

    abstract class ComputeOutputNode {
        - texMgr_: TextureManager&
        - computeBus_: ComputeOutputBus&
        - outputColorId: uint32_t
        - outputF32Id: uint32_t
        + submitJob()
        + hasPendingJob(): bool
        + getConnectedTexture(): shared_ptr<Texture>
        + clearOutputs()
    }

    class NoiseGeneratorNode {
        - params_: NoiseParams
        - type_: NoiseType
        --
        NoiseType: kGradient | kFbm | kWorley
        NoiseParams: width, height, scale,
        offset, seed, octaves, persistence
        + execute()
        + setParams(p: NoiseParams)
    }

    class PatternGeneratorNode {
        - params_: PatternParams
        - type_: PatternType
        --
        PatternType: kBrick | kWood | kChain
        PatternParams: width, height, scale,
        thickness, smoothness
        + execute()
        + setParams(p: PatternParams)
    }

    class PrincipledBSDFNode {
        - matMgr_: MaterialManager&
        - texMgr_: TextureManager&
        - managerId_: uint32_t
        + execute()
    }

    class TextureLoadNode {
        - path_: filesystem::path
        - useMipmaps_: bool
        - loaded_: bool
        + execute()
        + setPath(p)
        + isLoaded(): bool
    }
}

' ─────────────────────────────────────────────
' PACKAGE: Rendering
' ─────────────────────────────────────────────
package "Rendering" {

    class Renderer {
        - graphicsQueue_: vk::Queue
        - frames_: vector<Frame>
        - framesInFlight_: uint32_t
        + beginFrame(): CommandBuffer&
        + submit(): RenderResult
        + getFramesInFlight(): uint32_t
    }

    class MaterialSystem {
        - device_: GfxDevice&
        - frames_: vector<Frame>
        --
        Frame: {diffuseBuffer,
          diffuseSpecBuffer,
          principledBuffer,
          descriptorSet}
        + update(mgr: MaterialManager&)
        + getDescriptorSet(): vk::DescriptorSet
    }

    class GraphicsPipeline {
        - pipeline_: vk::UniquePipeline
        - layout_: vk::PipelineLayout
        --
        «builder»
        + addShaderStage()
        + setTopology()
        + setPolygonMode()
        + setDepthState()
        + setBlendMode()
        + build(): GraphicsPipeline
    }
}

' ─────────────────────────────────────────────
' PACKAGE: GPU Layer
' ─────────────────────────────────────────────
package "GPU / Vulkan Layer" {

    class GfxDevice {
        - physDevice_: vk::PhysicalDevice
        - device_: vk::UniqueDevice
        - allocator_: vma::Allocator
        - queues_: Queues
        + get(): vk::Device
        + waitIdle()
    }

    class DeviceBuffers {
        - cpuBuffers_: shared_ptr<Buffers>
        - gpuBuffers_: map<size_t, DeviceBuffer>
        + getBufferAddress(view): uint64_t
        + getBuffer(view): DeviceBuffer&
    }

    class AsyncCompute {
        - computeQueue_: vk::Queue
        - commandPool_: vk::UniqueCommandPool
        + submit(task: ComputeTask): ComputeResult
    }
}

' ─────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────

' Inheritance
Material <|-- Diffuse
Material <|-- DiffuseSpecular
Material <|-- PrincipledBSDF
WorkflowNode <|-- ComputeOutputNode
WorkflowNode <|-- PrincipledBSDFNode
WorkflowNode <|-- TextureLoadNode
ComputeOutputNode <|-- NoiseGeneratorNode
ComputeOutputNode <|-- PatternGeneratorNode

' Asset Import composition
AssetManager "1" *-- "0..*" Asset : manages
AssetManager --> AssetImporter : uses
AssetImporter ..> Asset : <<creates>>

' Asset → Scene Graph
Asset "1" *-- "0..*" Scene
Asset "1" *-- "0..*" Node
Asset "1" *-- "0..*" Mesh
Asset "1" *-- "0..*" Primitive
Asset "1" *-- "0..*" Animation

' Scene Graph internal
Scene --> Node : root nodes
Node "1" o-- "0..*" Node : children
Node "0..1" --> Mesh
Node "0..1" --> Skin
Mesh "1" *-- "1..*" Primitive
Primitive --> Slot : materialSlot

' Material composition
MaterialManager "1" *-- "0..*" Diffuse
MaterialManager "1" *-- "0..*" DiffuseSpecular
MaterialManager "1" *-- "0..*" PrincipledBSDF
MaterialManager "1" *-- "0..*" Slot
Diffuse "1" --> "0..2" Texture
DiffuseSpecular "1" --> "0..3" Texture
PrincipledBSDF "1" --> "0..15" Texture

' Texture system
TextureManager "1" *-- "0..*" Texture
Texture "1" *-- "1" GfxTexture
Environment --> Texture : IBL maps

' Workflow
Workflow "1" *-- "0..*" WorkflowNode
ComputeOutputNode --> TextureManager : output textures
ComputeOutputNode --> AsyncCompute : submit GPU job
PrincipledBSDFNode --> MaterialManager
PrincipledBSDFNode --> TextureManager
TextureLoadNode --> TextureManager

' Rendering
MaterialSystem --> MaterialManager : reads
MaterialSystem --> GfxDevice
Renderer --> GfxDevice
GraphicsPipeline --> GfxDevice

' GPU layer
AssetImporter --> GfxDevice
AssetImporter --> DeviceBuffers
Primitive --> DeviceBuffers

@enduml
